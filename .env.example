# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
# Also used by the API server to build activation/reset links in notifications.
APP_URL="http://localhost:3000"

# --- BloomCore API (server/) ---
# Port HTTP de l'API (défaut 4000).
API_PORT=4000
# Secret de signature des tokens de session (HMAC). OBLIGATOIRE en production :
# min 16 caractères, aléatoire. En NODE_ENV=production, le serveur REFUSE de démarrer
# si ce secret est absent, trop court, ou laissé à une valeur d'exemple.
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
# Chemin du fichier SQLite. Vide = server/bloomcore.db ; ':memory:' pour les *.check.ts.
BLOOMCORE_DB=
# Base URL de l'API vue par le frontend Vite.
VITE_API_BASE=http://localhost:4000/api/v1
# Secret HMAC du webhook entrant École Bloom (POST /api/v1/webhooks/academy).
# Mêmes règles que AUTH_SECRET : obligatoire et fort en production.
ACADEMY_WEBHOOK_SECRET=
# Origines autorisées pour CORS, séparées par des virgules (S8). Vide en production = tout
# bloqué ; en dev, les ports Vite locaux sont acceptés par défaut.
CORS_ORIGINS=
# Mot de passe démo partagé pour le seed (S7). En production, laissé vide = aucun credential
# seedé, activation de compte obligatoire. Défini uniquement pour des démos/staging.
SEED_DEMO_PASSWORD=

# --- Canaux de notification réels (vides = adapters simulés, logs + outbox) ---
# Email (SMTP via nodemailer — `npm i nodemailer` pour activer l'envoi réel).
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_WHATSAPP_FROM=
